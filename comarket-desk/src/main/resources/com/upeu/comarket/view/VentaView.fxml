<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="540.0" minWidth="760.0" prefHeight="560.0" prefWidth="820.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.upeu.comarket.controller.VentaController">
    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            <Label text="Registro de Ventas" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            <Label text="Cabecera y detalle persistentes con SQLite." style="-fx-text-fill: #5f6b7a;" />
        </VBox>
    </top>

    <center>
        <VBox minHeight="430.0" spacing="12.0">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="6.0" />
            </padding>

            <GridPane hgap="12.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="80.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="180.0" />
                    <ColumnConstraints halignment="RIGHT" minWidth="75.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="34.0" />
                    <RowConstraints minHeight="34.0" />
                </rowConstraints>

                <Label text="Cliente:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtCliente" promptText="Ejemplo: Cliente mostrador"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Fecha:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <DatePicker fx:id="dpFecha" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label text="Producto:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <ComboBox fx:id="cboProducto" maxWidth="1.7976931348623157E308"
                          promptText="Seleccione un producto"
                          GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Cantidad:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <HBox spacing="10.0" GridPane.columnIndex="3" GridPane.rowIndex="1">
                    <TextField fx:id="txtCantidad" text="1" promptText="Ejemplo: 1" HBox.hgrow="ALWAYS" />
                    <Button text="Agregar" onAction="#onAgregarDetalleClick" />
                </HBox>
            </GridPane>

            <TableView fx:id="tablaDetalles" minHeight="220.0" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colProducto" prefWidth="360.0" text="Producto" />
                    <TableColumn fx:id="colCantidad" prefWidth="120.0" text="Cantidad" />
                    <TableColumn fx:id="colPrecio" prefWidth="150.0" text="Precio unitario" />
                    <TableColumn fx:id="colSubtotal" prefWidth="150.0" text="Subtotal" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Label fx:id="lblTotal" text="Total: S/ 0.00"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <Button text="Quitar detalle" onAction="#onQuitarDetalleClick" />
                <Button text="Nueva venta" onAction="#onNuevaVentaClick" />
                <Button text="Guardar venta" defaultButton="true" onAction="#onGuardarVentaClick" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
