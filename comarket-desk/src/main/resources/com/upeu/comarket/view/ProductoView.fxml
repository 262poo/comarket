<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0" prefWidth="820.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.upeu.comarket.controller.ProductoController">
    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            <Label text="Gestion de Productos" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            <Label text="CRUD persistente con SQLite usando la misma interfaz de servicio." style="-fx-text-fill: #5f6b7a;" />
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="6.0" />
            </padding>

            <GridPane hgap="12.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="90.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="180.0" />
                    <ColumnConstraints halignment="RIGHT" minWidth="80.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="160.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="34.0" />
                    <RowConstraints minHeight="34.0" />
                </rowConstraints>

                <Label text="Codigo:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtCodigo" promptText="Ejemplo: P001"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Nombre:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <TextField fx:id="txtNombre" promptText="Ejemplo: Arroz"
                           GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label text="Precio:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtPrecio" promptText="Ejemplo: 3.50"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Stock:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="txtStock" promptText="Ejemplo: 20"
                           GridPane.columnIndex="3" GridPane.rowIndex="1" />
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                <Button fx:id="btnNuevo" text="Nuevo" onAction="#onNuevoClick" />
                <Button fx:id="btnEditar" text="Editar" onAction="#onEditarClick" />
                <Button fx:id="btnAccion" text="Guardar" defaultButton="true" onAction="#onAccionClick" />
                <Button fx:id="btnEliminar" text="Eliminar" onAction="#onEliminarClick" />
                <Button fx:id="btnCancelar" text="Cancelar" cancelButton="true" onAction="#onCancelarClick" />
            </HBox>

            <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCodigo" prefWidth="120.0" text="Codigo" />
                    <TableColumn fx:id="colNombre" prefWidth="360.0" text="Nombre" />
                    <TableColumn fx:id="colPrecio" prefWidth="150.0" text="Precio" />
                    <TableColumn fx:id="colStock" prefWidth="150.0" text="Stock" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
