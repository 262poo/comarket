<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0" prefWidth="820.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.upeu.comarket.controller.ReporteVentasController">
    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            <Label text="Reporte de Ventas" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            <Label text="Filtros, maestro-detalle, totales y verificacion de consistencia." style="-fx-text-fill: #5f6b7a;" />
        </VBox>
    </top>

    <center>
        <VBox spacing="14.0">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="6.0" />
            </padding>

            <GridPane hgap="12.0" vgap="10.0">
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="80.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" />
                    <ColumnConstraints halignment="RIGHT" minWidth="90.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="145.0" />
                    <ColumnConstraints halignment="RIGHT" minWidth="90.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="145.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="34.0" />
                    <RowConstraints minHeight="34.0" />
                </rowConstraints>

                <Label text="Cliente:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtFiltroCliente" promptText="Texto del cliente"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Desde:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <DatePicker fx:id="dpFechaDesde" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label text="Hasta:" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                <DatePicker fx:id="dpFechaHasta" GridPane.columnIndex="5" GridPane.rowIndex="0" />

                <Label text="Usuario:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtFiltroUsuario" promptText="Ejemplo: admin"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Estado:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <ComboBox fx:id="cboEstado" maxWidth="1.7976931348623157E308"
                          GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <HBox alignment="CENTER_RIGHT" spacing="10.0"
                      GridPane.columnIndex="4" GridPane.columnSpan="2" GridPane.rowIndex="1">
                    <Button text="Buscar" defaultButton="true" onAction="#onBuscarClick" />
                    <Button text="Limpiar" onAction="#onLimpiarFiltrosClick" />
                </HBox>
            </GridPane>

            <Label fx:id="lblResumenConsulta" text="Ventas: 0 | Total mostrado: S/ 0.00"
                   style="-fx-font-weight: bold;" />

            <TableView fx:id="tablaVentas" prefHeight="210.0">
                <columns>
                    <TableColumn fx:id="colVentaId" prefWidth="80.0" text="ID" />
                    <TableColumn fx:id="colCliente" prefWidth="300.0" text="Cliente" />
                    <TableColumn fx:id="colFecha" prefWidth="140.0" text="Fecha" />
                    <TableColumn fx:id="colTotalVenta" prefWidth="130.0" text="Total" />
                    <TableColumn fx:id="colEstado" prefWidth="110.0" text="Estado" />
                    <TableColumn fx:id="colUsuario" prefWidth="130.0" text="Usuario" />
                </columns>
            </TableView>

            <Label fx:id="lblVentaSeleccionada" text="Seleccione una venta para ver el detalle."
                   style="-fx-font-weight: bold;" />
            <Label fx:id="lblConsistencia" text="" style="-fx-text-fill: #5f6b7a;" />

            <TableView fx:id="tablaDetallesVenta" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDetalleProducto" prefWidth="360.0" text="Producto" />
                    <TableColumn fx:id="colDetalleCantidad" prefWidth="120.0" text="Cantidad" />
                    <TableColumn fx:id="colDetallePrecio" prefWidth="150.0" text="Precio unitario" />
                    <TableColumn fx:id="colDetalleSubtotal" prefWidth="150.0" text="Subtotal" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
