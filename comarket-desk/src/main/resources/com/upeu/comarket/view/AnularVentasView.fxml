<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0" prefWidth="820.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.upeu.comarket.controller.AnularVentasController">
    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                    <Label text="Ventas Registradas" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                    <Label text="Seleccione una venta para revisar su detalle." style="-fx-text-fill: #5f6b7a;" />
                </VBox>
                <Button text="Anular venta" onAction="#onAnularVentaClick" />
                <Button text="Actualizar" onAction="#onActualizarClick" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="14.0">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="6.0" />
            </padding>

            <TableView fx:id="tablaVentas" prefHeight="210.0">
                <columns>
                    <TableColumn fx:id="colVentaId" prefWidth="80.0" text="ID" />
                    <TableColumn fx:id="colCliente" prefWidth="330.0" text="Cliente" />
                    <TableColumn fx:id="colFecha" prefWidth="160.0" text="Fecha" />
                    <TableColumn fx:id="colTotalVenta" prefWidth="160.0" text="Total" />
                    <TableColumn fx:id="colEstado" prefWidth="120.0" text="Estado" />
                    <TableColumn fx:id="colUsuario" prefWidth="130.0" text="Usuario" />
                </columns>
            </TableView>

            <Label fx:id="lblVentaSeleccionada" text="Seleccione una venta para ver el detalle."
                   style="-fx-font-weight: bold;" />

            <TableView fx:id="tablaDetallesVenta" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDetalleProducto" prefWidth="360.0" text="Producto" />
                    <TableColumn fx:id="colDetalleCantidad" prefWidth="120.0" text="Cantidad" />
                    <TableColumn fx:id="colDetallePrecio" prefWidth="150.0" text="Precio unitario" />
                    <TableColumn fx:id="colDetalleSubtotal" prefWidth="150.0" text="Subtotal" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
