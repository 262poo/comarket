<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="260.0" prefWidth="420.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.upeu.comarket.controller.LoginController">
    <center>
        <VBox spacing="16.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="24.0" left="28.0" right="28.0" top="24.0" />
            </padding>

            <VBox spacing="4.0">
                <Label text="CoMarket Desk" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                <Label text="Ingrese con su usuario para continuar." style="-fx-text-fill: #5f6b7a;" />
            </VBox>

            <GridPane hgap="12.0" vgap="10.0">
                <Label text="Usuario:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtUsername" text="admin" promptText="admin"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Clave:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <PasswordField fx:id="txtPassword" text="123456" promptText="123456"
                               GridPane.columnIndex="1" GridPane.rowIndex="1" />
            </GridPane>

            <HBox alignment="CENTER_RIGHT">
                <Button text="Ingresar" defaultButton="true" onAction="#onIngresarClick" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
