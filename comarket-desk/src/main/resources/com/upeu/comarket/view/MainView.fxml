<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.upeu.comarket.controller.MainController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <padding>
                <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
            </padding>
            <Label text="CoMarket Desk" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Usuario:" />
            <Label fx:id="lblUsuario" style="-fx-font-weight: bold;" />
            <Button text="Cerrar sesion" onAction="#onCerrarSesionClick" />
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab fx:id="tabProductos" text="Productos">
                    <fx:include fx:id="productoView" source="ProductoView.fxml" />
                </Tab>
                <Tab text="Ventas">
                    <fx:include source="VentaView.fxml" />
                </Tab>
                <Tab fx:id="tabConsultaVentas" text="Consulta de ventas">
                    <fx:include fx:id="consultaVentasView" source="ConsultaVentasView.fxml" />
                </Tab>
                <Tab text="Reporte de ventas">
                    <fx:include source="ReporteVentasView.fxml" />
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
